# ── Sonnet-AI Environment Variables ────────────────────────────────────────

# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# Slack Integration
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# Jira Integration
JIRA_ENABLED=false
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# VirusTotal Enrichment
VIRUSTOTAL_ENABLED=false
VIRUSTOTAL_API_KEY=

# Triage Tuning
FALSE_POSITIVE_THRESHOLD=0.7
ESCALATION_CONFIDENCE_THRESHOLD=0.6
LOG_LEVEL=INFO
