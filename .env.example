# ── Sonnet-AI Environment Variables ────────────────────────────────────────

# Anthropic API
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1024

# Slack Integration
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# Jira Integration
JIRA_ENABLED=false
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# VirusTotal Enrichment
VIRUSTOTAL_ENABLED=false
VIRUSTOTAL_API_KEY=

# Triage Tuning
FALSE_POSITIVE_THRESHOLD=0.7
ESCALATION_CONFIDENCE_THRESHOLD=0.6
LOG_LEVEL=INFO

# Autonomous Response
# WARNING: When AUTO_RESPONSE_ENABLED=true, high-confidence CRITICAL alerts
# will trigger response actions automatically without analyst confirmation.
# Only enable this after thorough testing with your EDR/firewall integrations.
AUTONOMY_THRESHOLD=0.95
AUTO_RESPONSE_ENABLED=false

# Privacy Mode — redact PII before sending alerts to Claude API
PRIVACY_MODE=false

# Crown Jewels — high-value assets that trigger automatic priority escalation
CROWN_JEWELS=DC01,FINANCE-SRV,PAYROLL-DB,CEO-LAPTOP

# Dashboard Authentication
# IMPORTANT: Change these before deploying. Use `python -c "import secrets; print(secrets.token_urlsafe(32))"` to generate JWT_SECRET.
DASHBOARD_EMAIL=admin@example.com
DASHBOARD_PASSWORD=CHANGE_ME_BEFORE_DEPLOYING
JWT_SECRET=GENERATE_WITH_python_-c_"import_secrets;_print(secrets.token_urlsafe(32))"
DASHBOARD_ROLE=admin

# Elasticsearch / SIEM Connector
ELASTIC_URL=http://localhost:9200
ELASTIC_USERNAME=
ELASTIC_PASSWORD=
ELASTIC_INDEX=sonnet-ai-alerts
ELASTIC_VERIFY_SSL=false

# Multi-Tenant Configuration
TENANTS=Acme Corp,TechStart,FinanceGroup
# Leave empty to allow admin access to all tenants; set to a tenant name to restrict analyst to that tenant only.
DASHBOARD_TENANT=
